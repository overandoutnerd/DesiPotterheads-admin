{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "strict": true,

        "esModuleInterop": true,

        "allowSyntheticDefaultImports": true,

        "resolveJsonModule": true,

        "isolatedModules": true,

        "skipLibCheck": true,

        "forceConsistentCasingInFileNames": true,

        "noEmit": true,

        "types": [
            "node"
        ]
    },

    "include": [
        "src"
    ]
}
